# Clipboard settings
set selection-clipboard clipboard

# Printing (macOS fix - opens Preview with native print dialog)
set print-command "zathura-print"

# UI settings
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set guioptions ""

# Font settings (larger hints and command mode)
set font "monospace 16"

# Link hint styling (Vimium-like)
set highlight-color "rgba(255, 220, 0, 0.8)"
set highlight-active-color "rgba(255, 127, 0, 0.8)"
set highlight-fg "rgba(0, 0, 0, 1.0)"

# Window settings
set window-title-basename true

# Window geometry - center half (Raycast style)
# For 2560x1440 effective resolution: half width (1280), full height minus menubar
set window-width 1280
set window-height 1415

# Search settings
set incremental-search true

# Key mappings
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
map g goto top
map G goto bottom
map F fullscreen
map f follow
map q quit
map [fullscreen] q quit
